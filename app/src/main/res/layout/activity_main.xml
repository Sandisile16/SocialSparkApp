<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- App title at the top -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="THE SOCIAL SPARK APP"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Input field where the user types time of day -->
    <EditText
        android:id="@+id/timeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Please Enter Time Of Day"
        android:layout_marginBottom="20dp"/>

    <!-- Button to generate a social suggestion -->
    <Button
        android:id="@+id/sparkButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Get The Social Spark"/>

    <!-- Button to reset input and suggestion -->
    <Button
        android:id="@+id/resetButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RESET"
        android:layout_marginTop="10dp"/>

    <!-- TextView to display the social suggestion -->
    <TextView
        android:id="@+id/resultText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginTop="30dp"/>

</LinearLayout>